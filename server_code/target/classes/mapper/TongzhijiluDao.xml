<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cl.dao.TongzhijiluDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.TongzhijiluEntity" id="tongzhijiluMap">
        <result property="tongzhibianhao" column="tongzhibianhao"/>
        <result property="yuyuebianhao" column="yuyuebianhao"/>
        <result property="yishengzhanghao" column="yishengzhanghao"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="tongzhitype" column="tongzhitype"/>
        <result property="jieshouqudao" column="jieshouqudao"/>
        <result property="jieshoudizhi" column="jieshoudizhi"/>
        <result property="fasongzhuangtai" column="fasongzhuangtai"/>
        <result property="fasongshijian" column="fasongshijian"/>
        <result property="chongshicishu" column="chongshicishu"/>
        <result property="shibaiyuanyin" column="shibaiyuanyin"/>
        <result property="chulizhuangtai" column="chulizhuangtai"/>
        <result property="chulishijian" column="chulishijian"/>
        <result property="chuliren" column="chuliren"/>
        <result property="beizhixinxi" column="beizhixinxi"/>
    </resultMap>

	<select id="selectListView" parameterType="com.baomidou.mybatisplus.mapper.Wrapper" resultType="com.cl.entity.view.TongzhijiluView">
		SELECT  tongzhijilu.* 
		FROM tongzhijilu  
		<where> 1=1 ${ew.sqlSegment} </where>
	</select>
	
	<select id="selectView" parameterType="com.baomidou.mybatisplus.mapper.Wrapper" resultType="com.cl.entity.view.TongzhijiluView">
		SELECT  tongzhijilu.* 
		FROM tongzhijilu  
		<where> 1=1 ${ew.sqlSegment} </where>
	</select>
	
	<select id="selectValue" parameterType="map" resultType="map">
		SELECT ${params.xColumn}, sum(${params.yColumn}) total FROM tongzhijilu
        <where> 1=1 ${ew.sqlSegment} </where>
        group by ${params.xColumn}
	</select>
	
	<select id="selectTimeStatValue" parameterType="map" resultType="map">
		SELECT 
			#{params.timeStatType} as timeStatType,
			DATE_FORMAT(#{params.timeStatType}, '%Y-%m-%d') AS timeValue,
			COUNT(*) as count 
		FROM tongzhijilu
        <where> 1=1 ${ew.sqlSegment} </where>
		GROUP BY timeValue
		ORDER BY timeValue
	</select>
	
	<select id="selectGroup" parameterType="map" resultType="map">
		SELECT ${params.column} , count(*) as count FROM tongzhijilu
        <where> 1=1 ${ew.sqlSegment} </where>
        GROUP BY ${params.column}
	</select>

</mapper>